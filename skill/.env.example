# ── CMC API ──────────────────────────────────────────────────────────────────
CMC_API_KEY=5a4f3407d9c948408748e98afe8193fe
CMC_MCP_ENDPOINT=https://pro-api.coinmarketcap.com/mcp

# ── Transport ─────────────────────────────────────────────────────────────────
# Set USE_REST=1 if MCP is unavailable or for first-time testing
USE_REST=0

# ── x402 Micropayments ────────────────────────────────────────────────────────
# Set X402_ENABLED=1 to target Best Use of Agent Hub special prize
X402_ENABLED=0
X402_WALLET_KEY=your_signing_key_here
X402_MAX_AMOUNT=100

# ── BSC Testnet Attestation ───────────────────────────────────────────────────
BSC_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
APEX_CONTRACT=0x...        # paste after deploying ApexAttestation.sol
PRIVATE_KEY=0x...          # throwaway EOA only — never a funded operational key
DRY_RUN=1                  # set 0 to write real txs to BSC Testnet

# ── Ledger ────────────────────────────────────────────────────────────────────
APEX_LEDGER=ledger.jsonl

# ── Identity ──────────────────────────────────────────────────────────────────
APEX_AGENT_ID=             # filled after register_identity.py
APEX_SKILL_URL=https://your-vercel-url.vercel.app
